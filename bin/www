#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('nnptud-c5:server');
var http = require('http');

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

const { Server } = require("socket.io");
const io = new Server(server, {
  cors: {
    origin: process.env.CORS_ORIGIN || '*',
    methods: ["GET", "POST"]
  }
});

// ✅ Tách biệt: bin/www chỉ khởi tạo server & io.
// Toàn bộ business logic chat nằm tại socketHandlers/chatHandler.js
const registerChatHandlers = require('../socketHandlers/chatHandler');
registerChatHandlers(io);

// Đính kèm io vào biến app để các Controller nội bộ khác có thể gọi bắn dữ liệu realtime
app.set('io', io);

/**
 * Listen on provided port, on all network interfaces.
 */

server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof port === 'string'
    ? 'Pipe ' + port
    : 'Port ' + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  console.log('\n╔══════════════════════════════════════╗');
  console.log('║   🚀 OmniShop API Server Running 🚀   ║');
  console.log('╠══════════════════════════════════════╣');
  console.log('║  Listening on:', bind + ' '.repeat(Math.max(0, 19 - bind.length)) + '║');
  console.log('║  Environment:', (process.env.NODE_ENV || 'development').padEnd(18) + '║');
  console.log('║  API URL: http://localhost:' + addr.port + ' '.repeat(Math.max(0, 14 - String(addr.port).length)) + '║');
  console.log('╚══════════════════════════════════════╝\n');
}
