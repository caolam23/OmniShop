              "listen": "test",
              "script": {
                "exec": [
                  "console.log('🧪 TEST: Valid Products Import');",
                  "console.log('Expected: 3 products imported successfully');",
                  "var jsonData = pm.response.json();",
                  "if (pm.response.code === 201 && jsonData.data.importedCount === 3) {",
                  "  console.log('✅ PASS: All 3 products imported');",
                  "  postman.setNextRequest('Verify Products in Database');",
                  "} else {",
                  "  console.log('❌ FAIL: Expected 3 products, got ' + jsonData.data.importedCount);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
