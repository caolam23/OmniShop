# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/OmniShop

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Environment
NODE_ENV=development

# Server Port
PORT=3000

